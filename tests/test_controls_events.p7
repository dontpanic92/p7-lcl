@test(expected_type = "string", expected_value = "Ready:Files:output.txt:Options")
fn test_status_dialog_and_group_box_properties() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let status = lcl.new_status_bar(form);
    let open = lcl.new_open_dialog(form);
    let save = lcl.new_save_dialog(form);
    let group = lcl.new_group_box(form);
    let label = lcl.new_label(form);

    lcl.set_status_bar_simple_panel(status, true);
    lcl.set_status_bar_simple_text(status, "Ready");
    lcl.set_open_dialog_file_name(open, "input.txt");
    lcl.set_open_dialog_filter(open, "Files|*.*");
    lcl.set_save_dialog_file_name(save, "output.txt");
    lcl.set_open_dialog_filter(save, "Text|*.txt");
    lcl.set_group_box_caption(group, "Options");
    lcl.set_component_name(group, "OptionsGroup");
    lcl.set_control_parent(label, group);

    let result = if lcl.status_bar_simple_panel(status)
        && lcl.open_dialog_file_name(open) == "input.txt"
        && lcl.open_dialog_filter(save) == "Text|*.txt"
        && lcl.component_name(lcl.control_parent(label)) == "OptionsGroup" {
        lcl.status_bar_simple_text(status)
            + ":Files:"
            + lcl.save_dialog_file_name(save)
            + ":"
            + lcl.group_box_caption(group)
    } else {
        "failed"
    };
    lcl.free_label(label);
    lcl.free_group_box(group);
    lcl.free_save_dialog(save);
    lcl.free_open_dialog(open);
    lcl.free_status_bar(status);
    lcl.free_form(form);
    result
}

@test(runtime_error = "message-pump turn count must be non-negative")
fn test_bounded_message_pump_rejects_negative_turns() {
    lcl.initialize();
    let ignored = lcl.process_messages_bounded(-1);
}

@test(runtime_error = "application run cannot be restarted")
fn test_application_terminate_is_idempotent_and_run_cannot_restart() {
    lcl.initialize();
    let form = lcl.new_form();
    lcl.register_main_form(form);
    lcl.queue(() => {
        lcl.terminate();
        lcl.terminate();
    });
    lcl.run();
    lcl.run();
    lcl.free_form(form);
}
