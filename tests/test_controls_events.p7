@test(expected_type = "string", expected_value = "beta:1")
fn test_list_box_uses_indexed_item_api_and_selection_event() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let list = lcl.new_list_box(form);
    let first = lcl.list_box_add_item(list, "alpha");
    let second = lcl.list_box_add_item(list, "bravo");
    lcl.list_box_set_item(list, second, "beta");
    lcl.list_box_on_selection_change(list, (sender: handle<lcl.Control>) => {
        let actual = sender as handle<lcl.ListBox>;
        lcl.set_component_name(actual, "selected");
    });
    lcl.list_box_select_index(list, second);
    let item = lcl.list_box_item(list, lcl.list_box_item_index(list));
    let result = if first == 0
        && lcl.list_box_item_count(list) == 2
        && lcl.component_name(list) == "selected" {
        item + ":1"
    } else {
        "failed"
    };
    lcl.list_box_delete_item(list, first);
    lcl.list_box_clear_items(list);
    lcl.list_box_clear_on_selection_change(list);
    lcl.free_list_box(list);
    lcl.free_form(form);
    result
}

