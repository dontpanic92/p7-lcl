import test.test;
import lcl;

@test(expected_type = "string", expected_value = "sync")
fn test_application_invoke_runs_on_ui_thread() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.invoke(() => {
        lcl.set_label_caption(label, "sync");
    });
    let result = lcl.label_caption(label);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "queued")
fn test_application_queue_runs_during_message_pump() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.set_label_caption(label, "waiting");
    lcl.queue(() => {
        lcl.set_label_caption(label, "queued");
    });
    lcl.process_messages();
    let result = lcl.label_caption(label);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "clicked")
fn test_button_click_invokes_rooted_callback() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let button = lcl.new_button(form);
    lcl.set_label_caption(label, "waiting");
    lcl.button_on_click(button, () => {
        lcl.set_label_caption(label, "clicked");
    });
    lcl.click_button(button);
    let result = lcl.label_caption(label);
    lcl.free_button(button);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "int", expected_value = "1")
fn test_button_click_can_release_its_button_safely() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let button = lcl.new_button(form);
    lcl.button_on_click(button, () => {
        lcl.free_button(button);
    });
    lcl.click_button(button);
    lcl.process_messages();
    lcl.free_form(form);
    1
}

@test(expected_type = "string", expected_value = "changed")
fn test_edit_change_reenters_lcl() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let edit = lcl.new_edit(form);
    lcl.edit_on_change(edit, () => {
        lcl.set_label_caption(label, "changed");
    });
    lcl.set_edit_text(edit, "new text");
    let result = lcl.label_caption(label);
    lcl.free_edit(edit);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "int", expected_value = "1")
fn test_edit_change_can_release_its_edit_safely() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let edit = lcl.new_edit(form);
    lcl.edit_on_change(edit, () => {
        lcl.free_edit(edit);
    });
    lcl.set_edit_text(edit, "release");
    lcl.process_messages();
    lcl.free_form(form);
    1
}

@test(expected_type = "string", expected_value = "replacement")
fn test_replacing_event_releases_old_callback() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let button = lcl.new_button(form);
    lcl.button_on_click(button, () => {
        lcl.set_label_caption(label, "old");
    });
    lcl.button_on_click(button, () => {
        lcl.set_label_caption(label, "replacement");
    });
    lcl.click_button(button);
    let result = lcl.label_caption(label);
    lcl.free_button(button);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "waiting")
fn test_clearing_event_unregisters_callback() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let button = lcl.new_button(form);
    lcl.set_label_caption(label, "waiting");
    lcl.button_on_click(button, () => {
        lcl.set_label_caption(label, "clicked");
    });
    lcl.button_clear_on_click(button);
    lcl.click_button(button);
    let result = lcl.label_caption(label);
    lcl.free_button(button);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(runtime_error = "Protosept event callback failed")
fn test_synchronous_event_callback_error_is_propagated() {
    lcl.initialize();
    let form = lcl.new_form();
    let dead_label = lcl.new_label(form);
    let button = lcl.new_button(form);
    lcl.free_label(dead_label);
    lcl.button_on_click(button, () => {
        let ignored = lcl.label_caption(dead_label);
    });
    lcl.click_button(button);
    lcl.free_button(button);
    lcl.free_form(form);
}

@test(expected_type = "string", expected_value = "queried")
fn test_close_query_returns_mutable_result() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.form_on_close_query(form, () => {
        lcl.set_label_caption(label, "queried");
        false
    });
    lcl.close_form(form);
    let result = lcl.label_caption(label);
    lcl.form_clear_on_close_query(form);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(runtime_error = "Protosept event callback failed")
fn test_close_query_callback_error_is_propagated() {
    lcl.initialize();
    let form = lcl.new_form();
    let dead_label = lcl.new_label(form);
    lcl.free_label(dead_label);
    lcl.form_on_close_query(form, () => {
        let ignored = lcl.label_caption(dead_label);
        true
    });
    lcl.close_form(form);
    lcl.free_form(form);
}

@test(expected_type = "int", expected_value = "1")
fn test_on_close_can_release_its_form_safely() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    lcl.form_on_close(form, () => {
        lcl.free_form(form);
    });
    lcl.close_form(form);
    lcl.process_messages();
    1
}

@test(expected_type = "int", expected_value = "0")
fn test_key_press_callback_can_suppress_key() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let edit = lcl.new_edit(form);
    lcl.edit_on_key_press(edit, (key: int) => {
        if key == 97 {
            0
        } else {
            key
        }
    });
    let result = lcl.edit_send_key_press(edit, 97);
    lcl.edit_clear_on_key_press(edit);
    lcl.free_edit(edit);
    lcl.free_form(form);
    result
}

@test(runtime_error = "status StaleHandle")
fn test_released_button_is_rejected() {
    lcl.initialize();
    let form = lcl.new_form();
    let button = lcl.new_button(form);
    lcl.free_button(button);
    lcl.click_button(button);
    lcl.free_form(form);
}

@test(runtime_error = "status StaleHandle")
fn test_form_destruction_invalidates_owned_child() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.free_form(form);
    lcl.label_caption(label)
}

@test(expected_type = "int", expected_value = "42")
fn test_hierarchy_common_properties_and_panel_parenting() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let panel = lcl.new_panel(form);
    let button = lcl.new_button(form);
    let label = lcl.new_label(form);
    let edit = lcl.new_edit(form);

    let button_control: handle<lcl.Control> = button;
    let button_again = button_control as handle<lcl.Button>;
    let button_window: handle<lcl.WinControl> = button;
    lcl.set_component_name(button, "ActionButton");
    lcl.set_component_name(panel, "ContainerPanel");
    lcl.set_control_parent(button_control, panel);
    lcl.set_control_parent(label, panel);
    lcl.set_control_parent(edit, panel);
    lcl.set_control_bounds(panel, 8, 8, 240, 100);
    lcl.set_control_bounds(button_control, 12, 12, 80, 28);
    lcl.set_control_visible(button_again, true);
    lcl.set_control_enabled(button_again, true);
    lcl.set_control_align(label, lcl.Align.Top);
    lcl.set_control_anchors(edit, lcl.Anchors.Left | lcl.Anchors.Right | lcl.Anchors.Top);
    lcl.set_control_color(panel, lcl.Color.White);
    lcl.set_win_control_tab_order(button_window, 0);
    let _can_focus = lcl.win_control_can_focus(button_window);
    lcl.hide_control(label);
    lcl.show_control(label);

    let parent = lcl.control_parent(button_control);
    let owner = lcl.component_owner(button);
    lcl.set_component_name(owner, "OwnerForm");
    let mut checks = 0;
    if lcl.control_left(button_control) as int == 12 { checks = checks + 1; }
    if lcl.control_top(button_control) as int == 12 { checks = checks + 2; }
    if lcl.control_width(button_control) as int == 80 { checks = checks + 4; }
    if lcl.control_height(button_control) as int == 28 { checks = checks + 8; }
    if lcl.control_visible(button_control) { checks = checks + 16; }
    if lcl.control_enabled(button_control) { checks = checks + 32; }
    if lcl.control_align(label).value() as int == lcl.Align.Top.value() as int { checks = checks + 64; }
    if lcl.control_anchors(edit).contains(lcl.Anchors.Right) { checks = checks + 128; }
    if lcl.control_color(panel).value() as int == lcl.Color.White.value() as int { checks = checks + 256; }
    if lcl.win_control_tab_order(button_window) as int == 0 { checks = checks + 512; }
    if lcl.component_name(parent) == "ContainerPanel" { checks = checks + 1024; }
    if lcl.component_name(owner) == "OwnerForm" { checks = checks + 2048; }

    lcl.free_edit(edit);
    lcl.free_label(label);
    lcl.free_button(button);
    lcl.free_panel(panel);
    lcl.free_form(form);
    if checks == 4095 { 42 } else { 0 }
}

@test(runtime_error = "dynamic type_tag 'lcl.TLabel' is not a 'lcl.TButton'")
fn test_checked_downcast_rejects_wrong_real_lcl_type() {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let control: handle<lcl.Control> = label;
    let _button = control as handle<lcl.Button>;
    lcl.free_label(label);
    lcl.free_form(form);
}

@test(runtime_error = "invalid TAlign value")
fn test_invalid_align_is_rejected() {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.set_control_align(label, lcl.Align(99));
    lcl.free_label(label);
    lcl.free_form(form);
}

@test(runtime_error = "invalid TAnchors bit set")
fn test_invalid_anchor_bits_are_rejected() {
    lcl.initialize();
    let form = lcl.new_form();
    let edit = lcl.new_edit(form);
    lcl.set_control_anchors(edit, lcl.Anchors(16));
    lcl.free_edit(edit);
    lcl.free_form(form);
}

@test(runtime_error = "control width and height must be non-negative")
fn test_negative_control_extent_is_rejected() {
    lcl.initialize();
    let form = lcl.new_form();
    let panel = lcl.new_panel(form);
    lcl.set_control_bounds(panel, 0, 0, -1, 20);
    lcl.free_panel(panel);
    lcl.free_form(form);
}

@test(runtime_error = "tab order must be non-negative")
fn test_negative_tab_order_is_rejected() {
    lcl.initialize();
    let form = lcl.new_form();
    let button = lcl.new_button(form);
    lcl.set_win_control_tab_order(button, -1);
    lcl.free_button(button);
    lcl.free_form(form);
}
