@test(expected_type = "string", expected_value = "Open:1")
fn test_menu_hierarchy_state_and_click_event() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let menu = lcl.new_main_menu(form);
    let file = lcl.new_menu_item(menu);
    let open = lcl.new_submenu_item(file);
    lcl.set_form_main_menu(form, menu);
    lcl.set_menu_item_caption(file, "File");
    lcl.set_menu_item_caption(open, "Open");
    lcl.set_menu_item_enabled(open, true);
    lcl.set_menu_item_checked(open, true);
    lcl.menu_item_on_click(open, (sender: handle<lcl.Component>) => {
        let actual = sender as handle<lcl.MenuItem>;
        lcl.set_component_name(actual, "clicked");
    });
    lcl.click_menu_item(open);
    let child = lcl.menu_item(file, 0);
    let result = if lcl.menu_item_count(file) == 1
        && lcl.menu_item_caption(child) == "Open"
        && lcl.menu_item_enabled(open)
        && lcl.menu_item_checked(open)
        && lcl.component_name(open) == "clicked" {
        lcl.menu_item_caption(open) + ":1"
    } else {
        "failed"
    };
    lcl.menu_item_clear_on_click(open);
    lcl.free_menu_item(open);
    lcl.free_menu_item(file);
    lcl.free_main_menu(menu);
    lcl.free_form(form);
    result
}

