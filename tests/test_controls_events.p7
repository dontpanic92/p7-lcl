@test(expected_type = "int", expected_value = "0")
fn test_key_press_callback_can_suppress_key() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let edit = lcl.new_edit(form);
    lcl.edit_on_key_press(edit, (key: int) => {
        if key == 97 {
            0
        } else {
            key
        }
    });
    let result = lcl.edit_send_key_press(edit, 97);
    lcl.edit_clear_on_key_press(edit);
    lcl.free_edit(edit);
    lcl.free_form(form);
    result
}

