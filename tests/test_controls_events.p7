@test(expected_type = "int", expected_value = "1")
fn test_mouse_event_can_release_button_safely() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let button = lcl.new_button(form);
    lcl.button_on_mouse_down(button, (
        sender: handle<lcl.Control>,
        mouse_button: int,
        shift: int,
        x: int,
        y: int
    ) => {
        let actual = sender as handle<lcl.Button>;
        lcl.free_button(actual);
    });
    lcl.button_send_mouse_down(
        button,
        lcl.MouseButton.Left,
        lcl.ShiftState.None,
        0,
        0
    );
    lcl.process_messages();
    lcl.free_form(form);
    1
}

@test(expected_type = "int", expected_value = "1")
fn test_key_event_can_release_edit_safely() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let edit = lcl.new_edit(form);
    lcl.edit_on_key_down(edit, (
        sender: handle<lcl.Control>,
        key: int,
        shift: int
    ) => {
        let actual = sender as handle<lcl.Edit>;
        lcl.free_edit(actual);
        key
    });
    let ignored = lcl.edit_send_key_down(edit, 65, lcl.ShiftState.None);
    lcl.process_messages();
    lcl.free_form(form);
    1
}
