@test(expected_type = "string", expected_value = "MainForm")
fn test_application_main_form_registration_returns_borrowed_form() -> string {
    lcl.initialize();
    lcl.initialize();
    let form = lcl.new_form();
    let other = lcl.new_form();
    lcl.register_main_form(form);
    let registered = lcl.main_form();
    lcl.set_component_name(registered, "MainForm");
    let result = lcl.component_name(registered);
    lcl.free_form(other);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "Replacement")
