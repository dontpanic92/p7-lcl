import test.test;
import lcl;

@test(expected_type = "string", expected_value = "sync")
fn test_application_invoke_runs_on_ui_thread() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.invoke(() => {
        lcl.set_label_caption(label, "sync");
    });
    let result = lcl.label_caption(label);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "queued")
fn test_application_queue_runs_during_message_pump() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.set_label_caption(label, "waiting");
    lcl.queue(() => {
        lcl.set_label_caption(label, "queued");
    });
    lcl.process_messages();
    let result = lcl.label_caption(label);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "clicked")
fn test_button_click_invokes_rooted_callback() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let button = lcl.new_button(form);
    lcl.set_label_caption(label, "waiting");
    lcl.button_on_click(button, () => {
        lcl.set_label_caption(label, "clicked");
    });
    lcl.click_button(button);
    let result = lcl.label_caption(label);
    lcl.free_button(button);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "int", expected_value = "1")
fn test_button_click_can_release_its_button_safely() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    let button = lcl.new_button(form);
    lcl.button_on_click(button, () => {
        lcl.free_button(button);
    });
    lcl.click_button(button);
    lcl.process_messages();
    lcl.free_form(form);
    1
}

@test(expected_type = "string", expected_value = "changed")
fn test_edit_change_reenters_lcl() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let edit = lcl.new_edit(form);
    lcl.edit_on_change(edit, () => {
        lcl.set_label_caption(label, "changed");
    });
    lcl.set_edit_text(edit, "new text");
    let result = lcl.label_caption(label);
    lcl.free_edit(edit);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

