}

@test(expected_type = "string", expected_value = "Exception: expected")
fn test_application_exception_callback_receives_class_and_message() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.application_on_exception((class_name: string, message: string) => {
        lcl.set_label_caption(label, class_name + ": " + message);
    });
    lcl.application_raise_exception("expected");
    lcl.application_clear_on_exception();
    let result = lcl.label_caption(label);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "queued")
fn test_bounded_message_pump_runs_requested_turns_without_blocking() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    lcl.set_label_caption(label, "waiting");
    lcl.queue(() => {
        lcl.set_label_caption(label, "queued");
    });
    let no_turns = lcl.process_messages_bounded(0);
    let turns = lcl.process_messages_bounded(1);
    let result = lcl.label_caption(label);
    lcl.free_label(label);
    lcl.free_form(form);
    if no_turns == 0 && turns == 1 { result } else { "wrong turns" }
}

@test(expected_type = "string", expected_value = "checked")
fn test_checkbox_state_caption_and_change_event() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let check = lcl.new_checkbox(form);
    lcl.set_checkbox_caption(check, "Enable");
    lcl.checkbox_on_change(check, (sender: handle<lcl.Control>) => {
        let actual = sender as handle<lcl.CheckBox>;
        lcl.set_component_name(actual, "changed");
        lcl.set_label_caption(label, "changed");
    });
    lcl.click_checkbox(check);
    let changed = lcl.label_caption(label);
    let result = if lcl.checkbox_checked(check)
        && lcl.checkbox_caption(check) == "Enable"
        && changed == "changed" {
        "checked"
    } else {
        "failed"
    };
    lcl.checkbox_clear_on_change(check);
    lcl.free_checkbox(check);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

@test(expected_type = "string", expected_value = "second")
fn test_radio_buttons_form_an_exclusive_group() -> string {
    lcl.initialize();
    let form = lcl.new_form();
    let label = lcl.new_label(form);
    let first = lcl.new_radio_button(form);
    let second = lcl.new_radio_button(form);
    lcl.set_radio_button_caption(first, "First");
    lcl.set_radio_button_caption(second, "Second");
    lcl.radio_button_on_change(second, (sender: handle<lcl.Control>) => {
        let actual = sender as handle<lcl.RadioButton>;
        lcl.set_component_name(actual, "changed");
        lcl.set_label_caption(label, "second");
    });
    lcl.click_radio_button(first);
    lcl.click_radio_button(second);
    let changed = lcl.label_caption(label);
    let result = if lcl.radio_button_checked(second)
        && !lcl.radio_button_checked(first)
        && changed == "second" {
        "second"
    } else {
        "failed"
    };
    lcl.radio_button_clear_on_change(second);
    lcl.free_radio_button(second);
    lcl.free_radio_button(first);
    lcl.free_label(label);
    lcl.free_form(form);
    result
}

