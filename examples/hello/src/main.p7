import lcl;

fn main() -> int {
    lcl.initialize();
    let form = lcl.new_form();
    lcl.set_form_caption(form, "Hello from Protosept");
    let correct = lcl.form_caption(form) == "Hello from Protosept";
    lcl.show_form(form);
    lcl.run();
    lcl.free_form(form);
    if correct {
        0
    } else {
        1
    }
}
